  <text x="430" y="221" text-anchor="middle"
    font-family="'Arial Black',Arial,sans-serif" font-weight="900" font-size="17" fill="#eeeeee">FreelanceGuard.py</text>
  <text x="430" y="242" text-anchor="middle"
    font-family="Arial,sans-serif" font-size="12" fill="#60607a">gl.Contract  ·  Python  ·  GenVM</text>
  <text x="430" y="260" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="10.5" fill="#382010">escrow  ·  state  ·  routing logic</text>

  <!-- Contract → nondet layer (straight down) -->
  <line x1="430" y1="272" x2="430" y2="308"
    stroke="#ff6b35" stroke-width="1.6" marker-end="url(#ao)"/>
  <text x="455" y="294"
    font-family="'Courier New',monospace" font-size="10" fill="#ff6b35">evaluate_submission()</text>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- LAYER 2 — NONDETERMINISTIC EXECUTION                   -->
  <!-- ══════════════════════════════════════════════════════ -->
  <text x="430" y="304" text-anchor="middle"
    font-family="'JetBrains Mono',monospace" font-size="10" font-weight="700"
    letter-spacing="4" fill="#2a2a44">LAYER 2  ·  NONDETERMINISTIC EXECUTION  ·  GenVM</text>

  <!-- WEB FETCH -->
  <rect x="52" y="312" width="342" height="82" rx="11"
    fill="#14100a" stroke="#fbbf24" stroke-width="1.3"/>
  <text x="223" y="340" text-anchor="middle"
    font-family="'Arial Black',Arial,sans-serif" font-weight="900" font-size="14" fill="#fbbf24">Live Web Fetch</text>
  <text x="223" y="360" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="11" fill="#60607a">gl.nondet.web.render( url )</text>
  <text x="223" y="380" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="10" fill="#3a300a">mode="text"  ·  no oracle  ·  direct HTTP</text>

  <!-- LLM EVAL -->
  <rect x="466" y="312" width="342" height="82" rx="11"
    fill="#150d05" stroke="#ff8040" stroke-width="1.3"/>
  <text x="637" y="340" text-anchor="middle"
    font-family="'Arial Black',Arial,sans-serif" font-weight="900" font-size="14" fill="#ff8040">LLM Evaluation</text>
  <text x="637" y="360" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="11" fill="#60607a">gl.nondet.exec_prompt( prompt )</text>
  <text x="637" y="380" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="10" fill="#3a1a05">criteria + content  →  verdict JSON</text>

  <!-- Contract splits: horizontal route to each box -->
  <polyline points="380,272 164,272 164,312"
    fill="none" stroke="#fbbf24" stroke-width="1.2" stroke-dasharray="4 3"
    marker-end="url(#ay)"/>
  <polyline points="480,272 637,272 637,312"
    fill="none" stroke="#ff8040" stroke-width="1.2" stroke-dasharray="4 3"
    marker-end="url(#ao)"/>

  <!-- Web → LLM pipeline connector -->
  <line x1="394" y1="353" x2="466" y2="353"
    stroke="#333348" stroke-width="1" stroke-dasharray="3 3"
    marker-end="url(#ao)"/>
  <text x="430" y="347" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="9" fill="#252540">content →</text>

  <!-- Layer 2 → Validators: straight vertical lines -->
  <line x1="164" y1="394" x2="164" y2="430"
    stroke="#3b82f6" stroke-width="1.2" stroke-dasharray="4 3" marker-end="url(#ab)"/>
  <line x1="430" y1="394" x2="430" y2="430"
    stroke="#3b82f6" stroke-width="1.2" stroke-dasharray="4 3" marker-end="url(#ab)"/>
  <line x1="637" y1="394" x2="637" y2="430"
    stroke="#3b82f6" stroke-width="1.2" stroke-dasharray="4 3" marker-end="url(#ab)"/>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- LAYER 3 — VALIDATORS                                   -->
  <!-- ══════════════════════════════════════════════════════ -->
  <text x="430" y="426" text-anchor="middle"
    font-family="'JetBrains Mono',monospace" font-size="10" font-weight="700"
    letter-spacing="4" fill="#2a2a44">LAYER 3  ·  VALIDATOR NODES</text>

  <!-- Validator A (left, under web fetch) -->
  <rect x="52" y="434" width="224" height="98" rx="11"
    fill="#08101e" stroke="#3b82f6" stroke-width="1.3"/>
  <text x="164" y="460" text-anchor="middle"
    font-family="'Arial Black',Arial,sans-serif" font-weight="900" font-size="13.5" fill="#3b82f6">Validator A</text>
  <rect x="104" y="466" width="120" height="17" rx="6"
    fill="rgba(59,130,246,0.12)" stroke="#3b82f6" stroke-width="0.8"/>
  <text x="164" y="479" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="9.5" fill="#3b82f6" font-weight="700">LEADER · GPT-4o</text>
  <text x="164" y="502" text-anchor="middle"
    font-family="Arial,sans-serif" font-size="11" fill="#506080">Proposes verdict</text>
  <text x="164" y="520" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="9.5" fill="#202040">fetches URL independently</text>

  <!-- Validator B (center, under pipeline midpoint) -->
  <rect x="318" y="434" width="224" height="98" rx="11"
    fill="#08101e" stroke="#3b82f6" stroke-width="1.3"/>
  <text x="430" y="460" text-anchor="middle"
    font-family="'Arial Black',Arial,sans-serif" font-weight="900" font-size="13.5" fill="#3b82f6">Validator B</text>
  <rect x="370" y="466" width="120" height="17" rx="6"
    fill="rgba(59,130,246,0.08)" stroke="#3b82f6" stroke-width="0.8"/>
  <text x="430" y="479" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="9.5" fill="#3b82f6" font-weight="700">VOTER · Claude 3.5</text>
  <text x="430" y="502" text-anchor="middle"
    font-family="Arial,sans-serif" font-size="11" fill="#506080">Verifies leader verdict</text>
  <text x="430" y="520" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="9.5" fill="#202040">equivalence check</text>

  <!-- Validator C (right, under LLM eval) -->
  <rect x="584" y="434" width="224" height="98" rx="11"
    fill="#08101e" stroke="#3b82f6" stroke-width="1.3"/>
  <text x="696" y="460" text-anchor="middle"
    font-family="'Arial Black',Arial,sans-serif" font-weight="900" font-size="13.5" fill="#3b82f6">Validator C</text>
  <rect x="636" y="466" width="120" height="17" rx="6"
    fill="rgba(59,130,246,0.08)" stroke="#3b82f6" stroke-width="0.8"/>
  <text x="696" y="479" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="9.5" fill="#3b82f6" font-weight="700">VOTER · LLaMA 3</text>
  <text x="696" y="502" text-anchor="middle"
    font-family="Arial,sans-serif" font-size="11" fill="#506080">Verifies leader verdict</text>
  <text x="696" y="520" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="9.5" fill="#202040">equivalence check</text>

  <!-- Validators → Consensus: angled into center box cleanly -->
  <polyline points="164,532 164,570 346,570 346,580"
    fill="none" stroke="#22c55e" stroke-width="1.3" marker-end="url(#ag)"/>
  <line x1="430" y1="532" x2="430" y2="580"
    stroke="#22c55e" stroke-width="1.3" marker-end="url(#ag)"/>
  <polyline points="696,532 696,570 514,570 514,580"
    fill="none" stroke="#22c55e" stroke-width="1.3" marker-end="url(#ag)"/>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- LAYER 4 — CONSENSUS                                    -->
  <!-- ══════════════════════════════════════════════════════ -->
  <text x="430" y="576" text-anchor="middle"
    font-family="'JetBrains Mono',monospace" font-size="10" font-weight="700"
    letter-spacing="4" fill="#2a2a44">LAYER 4  ·  CONSENSUS</text>

  <rect x="170" y="582" width="520" height="70" rx="12"
    fill="#091508" stroke="#22c55e" stroke-width="1.7"/>
  <rect x="170" y="582" width="520" height="3" rx="2" fill="#22c55e" opacity="0.45"/>
  <text x="430" y="614" text-anchor="middle"
    font-family="'Arial Black',Arial,sans-serif" font-weight="900" font-size="16" fill="#22c55e">Optimistic Democracy</text>
  <text x="430" y="638" text-anchor="middle"
    font-family="Arial,sans-serif" font-size="12" fill="#4a8a60">supermajority vote  →  finalized verdict</text>

  <!-- Consensus forks to two outcomes -->
  <!-- Left fork: rejected → refund -->
  <polyline points="320,652 320,704 178,704 178,732"
    fill="none" stroke="#14b8a6" stroke-width="1.4" marker-end="url(#at)"/>
  <text x="253" y="697" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="10" fill="#14b8a6">rejected</text>

  <!-- Right fork: accepted → pay -->
  <polyline points="540,652 540,704 682,704 682,732"
    fill="none" stroke="#22c55e" stroke-width="1.4" marker-end="url(#ag)"/>
  <text x="608" y="697" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="10" fill="#22c55e">accepted</text>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- LAYER 5 — FUND RELEASE                                 -->
  <!-- ══════════════════════════════════════════════════════ -->

  <!-- Refund box -->
  <rect x="52" y="732" width="252" height="66" rx="11"
    fill="#0b1f1e" stroke="#14b8a6" stroke-width="1.3"/>
  <text x="178" y="759" text-anchor="middle"
    font-family="'Arial Black',Arial,sans-serif" font-weight="900" font-size="14" fill="#14b8a6">Refund → Client</text>
  <text x="178" y="782" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="10" fill="#1e3a38">emit_transfer( client, budget )</text>

  <!-- Pay box -->
  <rect x="556" y="732" width="252" height="66" rx="11"
    fill="#091508" stroke="#22c55e" stroke-width="1.3"/>
  <text x="682" y="759" text-anchor="middle"
    font-family="'Arial Black',Arial,sans-serif" font-weight="900" font-size="14" fill="#22c55e">Pay → Freelancer</text>
  <text x="682" y="782" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="10" fill="#1a3a1a">emit_transfer( freelancer, budget )</text>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- LEGEND                                                 -->
  <!-- ══════════════════════════════════════════════════════ -->
  <rect x="0" y="826" width="860" height="74" fill="#05050d"/>
  <line x1="0" y1="826" x2="860" y2="826" stroke="#ffffff08" stroke-width="1"/>

  <!-- row 1 -->
  <circle cx="48" cy="850" r="5" fill="#14b8a6"/>
  <text x="59" y="854" font-family="'Courier New',monospace" font-size="10.5" fill="#40506a">Client / Freelancer</text>

  <circle cx="200" cy="850" r="5" fill="#ff6b35"/>
  <text x="211" y="854" font-family="'Courier New',monospace" font-size="10.5" fill="#40506a">Intelligent Contract</text>

  <circle cx="362" cy="850" r="5" fill="#fbbf24"/>
  <text x="373" y="854" font-family="'Courier New',monospace" font-size="10.5" fill="#40506a">Web Fetch</text>

  <circle cx="460" cy="850" r="5" fill="#ff8040"/>
  <text x="471" y="854" font-family="'Courier New',monospace" font-size="10.5" fill="#40506a">LLM Eval</text>

  <circle cx="558" cy="850" r="5" fill="#3b82f6"/>
  <text x="569" y="854" font-family="'Courier New',monospace" font-size="10.5" fill="#40506a">Validators</text>

  <circle cx="648" cy="850" r="5" fill="#22c55e"/>
  <text x="659" y="854" font-family="'Courier New',monospace" font-size="10.5" fill="#40506a">Consensus + Release</text>

  <!-- row 2 -->
  <line x1="48" y1="874" x2="76" y2="874" stroke="#333348" stroke-width="1.2" stroke-dasharray="4 3"/>
  <text x="84" y="878" font-family="'Courier New',monospace" font-size="10" fill="#252540">dashed = nondeterministic  (each validator runs independently)</text>
  <line x1="560" y1="874" x2="588" y2="874" stroke="#ff6b35" stroke-width="1.5"/>
  <text x="596" y="878" font-family="'Courier New',monospace" font-size="10" fill="#252540">solid = deterministic</text>
</svg>
