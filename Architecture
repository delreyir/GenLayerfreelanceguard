      <path d="M1 2L8.5 5L1 8" fill="none" stroke="#9d5ff5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
  </defs>

  <rect width="860" height="900" fill="#080810" rx="16"/>
  <rect width="860" height="900" fill="url(#dots)" rx="16"/>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- LAYER 0 — USERS                                        -->
  <!-- ══════════════════════════════════════════════════════ -->
  <text x="430" y="36" text-anchor="middle"
    font-family="'JetBrains Mono',monospace" font-size="10" font-weight="700"
    letter-spacing="4" fill="#2a2a44">LAYER 0  ·  USERS</text>

  <!-- Client -->
  <rect x="52" y="46" width="220" height="74" rx="11"
    fill="#0b1f1e" stroke="#14b8a6" stroke-width="1.4"/>
  <text x="162" y="74" text-anchor="middle"
    font-family="'Arial Black',Arial,sans-serif" font-weight="900" font-size="15" fill="#14b8a6">Client</text>
  <text x="162" y="94" text-anchor="middle"
    font-family="Arial,sans-serif" font-size="11.5" fill="#4a6070">Deposits GEN · creates job</text>
  <text x="162" y="111" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="10.5" fill="#1e3a38">post_job( value )</text>

  <!-- Freelancer -->
  <rect x="588" y="46" width="220" height="74" rx="11"
    fill="#130f1f" stroke="#9d5ff5" stroke-width="1.4"/>
  <text x="698" y="74" text-anchor="middle"
    font-family="'Arial Black',Arial,sans-serif" font-weight="900" font-size="15" fill="#9d5ff5">Freelancer</text>
  <text x="698" y="94" text-anchor="middle"
    font-family="Arial,sans-serif" font-size="11.5" fill="#4a6070">Submits completed work</text>
  <text x="698" y="111" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="10.5" fill="#2a1a4a">submit_work( url )</text>

  <!-- Client → Contract: go down, then right horizontally, then down into contract -->
  <polyline points="162,120 162,160 300,160 300,188"
    fill="none" stroke="#ff6b35" stroke-width="1.4" stroke-dasharray="5 4"
    marker-end="url(#ao)"/>
  <text x="234" y="154" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="10" fill="#ff6b35">post_job()</text>

  <!-- Freelancer → Contract: go down, then left horizontally, then down into contract -->
  <polyline points="698,120 698,160 560,160 560,188"
    fill="none" stroke="#9d5ff5" stroke-width="1.4" stroke-dasharray="5 4"
    marker-end="url(#ap)"/>
  <text x="632" y="154" text-anchor="middle"
    font-family="'Courier New',monospace" font-size="10" fill="#9d5ff5">submit_work()</text>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- LAYER 1 — INTELLIGENT CONTRACT                         -->
  <!-- ══════════════════════════════════════════════════════ -->
  <text x="430" y="183" text-anchor="middle"
    font-family="'JetBrains Mono',monospace" font-size="10" font-weight="700"
